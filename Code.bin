#include <SPI.h>
#include <MFRC522.h>
#include <SD.h>
#include <WiFi.h>
#include <WebServer.h>
#include <time.h>
#include <HTTPUpdate.h>

/* -------- WIFI -------- */
const char* ssid = "ASI";
const char* password = "ljapunov";

IPAddress local_IP(192, 168, 109, 99);
IPAddress gateway(192, 168, 109, 1);
IPAddress subnet(255, 255, 255, 0);
IPAddress primaryDNS(8, 8, 8, 8);
IPAddress secondaryDNS(8, 8, 4, 4);

/* -------- OTA -------- */
const char* firmwareURL = "https://github.com/TeodorTodorovski01/RFID_access-control/releases/download/v1.0/Code.ino.bin";
WiFiClient client; // OTA client

/* -------- TIME -------- */
const char* ntpServer = "pool.ntp.org";
const long  gmtOffset_sec = 3600;
const int   daylightOffset_sec = 3600;

/* -------- RFID -------- */
#define RFID_CS 5
#define RFID_RST 22
MFRC522 rfid(RFID_CS, RFID_RST);

/* -------- SD -------- */
#define SD_CS 25
#define SD_SCK 14
#define SD_MOSI 13
#define SD_MISO 12

#define ACCESS_PIN 4

SPIClass hspi(HSPI);
WebServer server(80);

bool sdReady = false;

/* -------- WATCHDOG -------- */
byte initialVersion = 0;
unsigned long lastRFIDCheck = 0;
const unsigned long rfidCheckInterval = 5000;

/* ================= TIME ================= */
String getTimestamp() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return "NO_TIME";
  char buffer[30];
  strftime(buffer, sizeof(buffer), "%Y-%m-%d %H:%M:%S", &timeinfo);
  return String(buffer);
}

/* ================= ERROR LOG ================= */
void logError(String msg) {
  if (!sdReady) return;

  File file = SD.open("/erordetekt.txt", FILE_APPEND);
  if (file) {
    file.print(getTimestamp());
    file.print(" | ");
    file.println(msg);
    file.close();
  }
}

void checkRFIDHealth() {

  byte version = rfid.PCD_ReadRegister(rfid.VersionReg);

  if (version == 0x00 || version == 0xFF) {
    logError("SPI ERROR - VersionReg invalid");
    delay(200);
    ESP.restart();
  }

  if (version != initialVersion) {
    logError("RFID VERSION MISMATCH");
    delay(200);
    ESP.restart();
  }
}

/* ================= AUTH ================= */
String checkAuthorization(String uid) {
  File file = SD.open("/avtorizirani.txt", FILE_READ);
  if (!file) return "";

  while (file.available()) {
    String line = file.readStringUntil('\n');
    line.trim();
    int tabIndex = line.indexOf('\t');
    if (tabIndex == -1) continue;

    String fileUID = line.substring(0, tabIndex);
    String fullName = line.substring(tabIndex + 1);

    fileUID.trim();
    fullName.trim();

    if (fileUID.equalsIgnoreCase(uid)) {
      file.close();
      return fullName;
    }
  }

  file.close();
  return "";
}

/* ================= OTA ================= */
void handleUpdate() {

  server.send(200, "text/html", "<h3>Updating... Do NOT turn off!</h3>");

  logError("OTA STARTED");

  httpUpdate.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);

  t_httpUpdate_return ret = httpUpdate.update(client, firmwareURL);

  switch (ret) {
    case HTTP_UPDATE_FAILED:
      Serial.println("OTA FAILED");
      logError("OTA FAILED");
      break;

    case HTTP_UPDATE_NO_UPDATES:
      Serial.println("NO UPDATE");
      logError("NO UPDATE");
      break;

    case HTTP_UPDATE_OK:
      Serial.println("OTA SUCCESS");
      logError("OTA SUCCESS");
      break;
  }
}

/* ================= WEB ================= */

void handleRoot() {

  String html = R"rawliteral(
  <html>
  <body>
  <h2>RFID Access System</h2>
  <p>IP: 192.168.109.99</p>

  <a href="/log">Live Log</a><br><br>
  <a href="/auth">View Authorized</a><br><br>
  <a href="/erordetekt">Error Log</a><br><br>

  <h3>Add Authorized User</h3>
  <form action="/add" method="POST">
    UID: <input name="uid"><br>
    Ime Prezime: <input name="name"><br>
    <input type="submit" value="Add">
  </form>

  <br><br>
  <form action="/reset" method="POST">
    <button type="submit">Restart ESP32</button>
  </form>

  <br><br>
  <form action="/unlock" method="POST">
    <button type="submit">Otkuci (2 sec)</button>
  </form>

  <br><br>
  <form action="/update" method="POST">
    <button style="background:red;color:white;padding:10px;border:none;border-radius:8px;">
      OTA Update
    </button>
  </form>

  </body>
  </html>
  )rawliteral";

  server.send(200, "text/html", html);
}

void handleErrorLog() {

  File file = SD.open("/erordetekt.txt", FILE_READ);
  if (!file) {
    server.send(200, "text/plain", "No error log.");
    return;
  }

  String content = "";
  while (file.available()) content += file.readString();
  file.close();

  server.send(200, "text/plain", content);
}

void handleLogPage() {

  String html = R"rawliteral(
  <html>
  <body>
  <h2>Live Log</h2>
  <pre id="logdata">Loading...</pre>

  <script>
  function loadLog() {
    fetch('/logdata')
      .then(response => response.text())
      .then(data => {
        document.getElementById('logdata').textContent = data;
      });
  }

  setInterval(loadLog, 2000);
  loadLog();
  </script>

  </body>
  </html>
  )rawliteral";

  server.send(200, "text/html", html);
}

void handleLogData() {
  File file = SD.open("/logus.txt", FILE_READ);
  if (!file) {
    server.send(200, "text/plain", "No log file.");
    return;
  }

  String content = "";
  while (file.available()) content += file.readString();
  file.close();

  server.send(200, "text/plain", content);
}

void handleAuth() {
  File file = SD.open("/avtorizirani.txt", FILE_READ);
  if (!file) {
    server.send(200, "text/plain", "No auth file.");
    return;
  }

  String content = "";
  while (file.available()) content += file.readString();
  file.close();

  server.send(200, "text/plain", content);
}

void handleAdd() {
  String uid = server.arg("uid");
  String name = server.arg("name");

  File file = SD.open("/avtorizirani.txt", FILE_APPEND);
  if (file) {
    file.print(uid);
    file.print("\t");
    file.println(name);
    file.close();
  }

  server.sendHeader("Location", "/");
  server.send(303);
}

void handleReset() {
  server.send(200, "text/html", "<h3>Restarting...</h3>");
  delay(1000);
  ESP.restart();
}

void handleUnlock() {
  digitalWrite(ACCESS_PIN, HIGH);
  delay(2000);
  digitalWrite(ACCESS_PIN, LOW);
  server.sendHeader("Location", "/");
  server.send(303);

  delay(200);
  ESP.restart();
}

/* ================= WIFI ================= */
void connectWiFi() {
  WiFi.config(local_IP, gateway, subnet, primaryDNS, secondaryDNS);
  WiFi.begin(ssid, password);

  while (WiFi.status() != WL_CONNECTED) delay(500);
}

/* ================= SETUP ================= */
void setup() {

  Serial.begin(115200);
  pinMode(ACCESS_PIN, OUTPUT);
  digitalWrite(ACCESS_PIN, LOW);

  connectWiFi();
  configTime(gmtOffset_sec, daylightOffset_sec, ntpServer);

  SPI.begin();
  rfid.PCD_Init();

  initialVersion = rfid.PCD_ReadRegister(rfid.VersionReg);

  hspi.begin(SD_SCK, SD_MISO, SD_MOSI, SD_CS);

  if (SD.begin(SD_CS, hspi, 1000000)) {
    sdReady = true;

    if (!SD.exists("/avtorizirani.txt")) {
      File f = SD.open("/avtorizirani.txt", FILE_WRITE);
      f.println("aa bb cc dd\tIme Prezime");
      f.close();
    }

    if (!SD.exists("/erordetekt.txt")) {
      File f = SD.open("/erordetekt.txt", FILE_WRITE);
      f.println("Error log initialized");
      f.close();
    }
  }

  server.on("/", handleRoot);
  server.on("/log", handleLogPage);
  server.on("/logdata", handleLogData);
  server.on("/auth", handleAuth);
  server.on("/erordetekt", handleErrorLog);
  server.on("/add", HTTP_POST, handleAdd);
  server.on("/reset", HTTP_POST, handleReset);
  server.on("/unlock", HTTP_POST, handleUnlock);
  server.on("/update", HTTP_POST, handleUpdate); // OTA

  server.begin();
}

/* ================= LOOP ================= */
void loop() {

  server.handleClient();

  if (millis() - lastRFIDCheck > rfidCheckInterval) {
    lastRFIDCheck = millis();
    checkRFIDHealth();
  }

  if (!rfid.PICC_IsNewCardPresent()) return;
  if (!rfid.PICC_ReadCardSerial()) return;

  String uidStr = "";
  for (byte i = 0; i < rfid.uid.size; i++) {
    if (rfid.uid.uidByte[i] < 0x10) uidStr += "0";
    uidStr += String(rfid.uid.uidByte[i], HEX);
  }

  uidStr.toUpperCase();

  String user = checkAuthorization(uidStr);

  if (user != "") {
    digitalWrite(ACCESS_PIN, HIGH);
    delay(2000);
    digitalWrite(ACCESS_PIN, LOW);

    if (sdReady) {
      File logFile = SD.open("/logus.txt", FILE_APPEND);
      if (logFile) {
        logFile.print(getTimestamp());
        logFile.print(" | ");
        logFile.print(uidStr);
        logFile.print(" | ");
        logFile.println(user);
        logFile.close();
      }
    }
  }

  rfid.PICC_HaltA();
}
